source "https://rubygems.org"

# The github-pages gem pins the exact same versions GitHub Pages runs, so your
# local preview matches production. (GitHub's classic Pages build ignores this
# file and uses its own copy — this Gemfile is only for local previewing.)
gem "github-pages", group: :jekyll_plugins

# Ruby 3.0+ removed WEBrick from the standard library; `jekyll serve` needs it.
gem "webrick", "~> 1.8"
